# RTC performance test configuration
# Copy this file to .env and fill in the values for your environment:
#
#   cp .env.example .env

# ── Host configuration ───────────────────────────────────────────────────────
# Set these before running setup.

# Absolute path to the WordPress root (the directory containing wp-config.php).
WP_PATH="/var/www/html"

# Public URL of the site being tested.
# Defaults to the siteurl value in the database if not set here.
#WP_URL="http://localhost"

# ── Test parameters ──────────────────────────────────────────────────────────
# These are all optional. The defaults shown are used if not set.

# Number of polls per client in single-poll scenarios (e.g. single-idle).
#POLLS=10

# Seconds between polls per client. Set to 0 for stress mode (no delay).
#POLL_DELAY=1

# Number of concurrent clients for multi-client scenarios (e.g. sustain, n-idle).
#N_CLIENTS=3

# How long in seconds to run the sustain scenario.
#DURATION=30

# Size of simulated update payloads sent by editing clients.
# Options: small (3 B)  medium (384 B)  large (3 kB)
#UPDATE_SIZE=small

# ── Generated by setup ───────────────────────────────────────────────────────
# The values below are written automatically by "bash rtc-test.sh setup".
# Do not edit them manually — re-run setup or refresh-auth to regenerate.
# They are shown here for documentation purposes only.

#WP_URL="<detected from database>"
#WP_USER="rtctest"
#WP_PASS="<random password set by setup>"
#WP_NONCE="<~12h nonce fetched by setup; refresh with: bash rtc-test.sh refresh-auth>"
#POST_ID="<ID of the dedicated test post created by setup>"
#_RTC_POST_ID_AUTO=1
