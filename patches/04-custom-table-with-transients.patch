+		$end_cursor = $response->get_data()['rooms'][0]['end_cursor'];
+
+		// Client 2 sends a compaction at the current cursor.
+		$compaction = array(
+			'type' => 'compaction',
+			'data' => 'Y29tcGFjdGVk',
+		);
+
+		$this->dispatch_collaboration(
