+				$this->build_room( $room, '1', 0, array( 'cursor' => 'initial' ) ),
+			)
+		);
+
+		// Client 1 updates awareness to a new value.
+		$response = $this->dispatch_collaboration(
+			array(
+				$this->build_room( $room, '1', 0, array( 'cursor' => 'updated' ) ),
+			)
