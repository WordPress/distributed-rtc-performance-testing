+				'data' => base64_encode( "update-$i" ),
+			);
+		}
+
+		// Client 1 sends enough updates to exceed the compaction threshold.
+		$response = $this->dispatch_collaboration(
+			array(
+				$this->build_room( $room, '1', 0, array( 'user' => 'c1' ), $updates ),
